<Window x:Class="WinWidgetTime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinWidgetTime.ViewModels"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        Title="WinWidgetTime">

    <Window.ContextMenu>
        <ContextMenu Background="#FF1E1E2E" BorderBrush="#FF454570">
            <ContextMenu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#FFCDD6F4"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
            </ContextMenu.Resources>
            <MenuItem Header="⚙  Settings" Click="Settings_Click"/>
            <MenuItem Header="?  About"    Click="About_Click"/>
            <Separator Background="#FF454570"/>
            <MenuItem Header="✕  Exit"     Click="Exit_Click"/>
        </ContextMenu>
    </Window.ContextMenu>

    <Border x:Name="WidgetBorder"
            Background="#CC000000"
            CornerRadius="10"
            Padding="14,8,14,10"
            MouseLeftButtonDown="Widget_MouseLeftButtonDown"
            MouseMove="Widget_MouseMove"
            MouseLeftButtonUp="Widget_MouseLeftButtonUp"
            MouseEnter="Widget_MouseEnter"
            MouseLeave="Widget_MouseLeave">

        <StackPanel>

            <!-- Header: title on left, icon buttons on right -->
            <Grid Height="22" Margin="0,0,0,5">
                <TextBlock x:Name="TitleText"
                           Text="🕐 World Clock (LanDen Labs)"
                           Foreground="#66FFFFFF"
                           FontSize="11"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
                <StackPanel x:Name="IconPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="Collapsed">
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="⚙"
                            ToolTip="Settings"
                            Click="Settings_Click"/>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Content="?"
                            ToolTip="About"
                            FontWeight="Bold"
                            Margin="3,0,0,0"
                            Click="About_Click"/>
                </StackPanel>
            </Grid>

            <Rectangle Height="1" Fill="#33FFFFFF" Margin="0,0,0,6"/>

            <!-- Time rows -->
            <ItemsControl x:Name="TimeList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TimeDisplayItem}">
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="110"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto" MinWidth="85"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto" MinWidth="105"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding Label}"
                                       Foreground="{Binding ColorBrush}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding DatePart}"
                                       Foreground="{Binding ColorBrush}"
                                       Opacity="0.75"
                                       VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="4"
                                       Text="{Binding TimePart}"
                                       Foreground="{Binding ColorBrush}"
                                       FontFamily="Consolas, Courier New"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</Window>
