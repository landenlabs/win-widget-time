<Window x:Class="WinWidgetTime.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About WinWidgetTime"
        Width="380" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        Foreground="#FFCDD6F4"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="182"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Company logo — video or static fallback -->
        <Image x:Name="LogoFallback" Grid.Row="0"
               Stretch="Uniform"
               Visibility="Collapsed"/>
        <MediaElement x:Name="LogoPlayer" Grid.Row="0"
                      LoadedBehavior="Play"
                      IsMuted="True"
                      Stretch="Uniform"
                      Visibility="Collapsed"/>

        <!-- App name + version -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="🕐  WinWidgetTime" FontSize="22" FontWeight="Bold"
                       Foreground="#FF7AA2F7"/>
            <TextBlock Text="v1.0  ·  World clock desktop widget"
                       Foreground="#FF6C7086" FontSize="12" Margin="0,4,0,0"/>
        </StackPanel>

        <Rectangle Grid.Row="3" Height="1" Fill="#FF313244" VerticalAlignment="Bottom"/>

        <!-- Info -->
        <StackPanel Grid.Row="4" Margin="0,14,0,0">
            <TextBlock TextWrapping="Wrap" Foreground="#FFBAC2DE" LineHeight="22">
                Displays live time for any city or time zone as a transparent overlay
                on your Windows desktop wallpaper.
            </TextBlock>
            <TextBlock Margin="0,12,0,0" Foreground="#FFBAC2DE" FontSize="11">
                <Run>Created by: LanDen Labs (2026)</Run>
            </TextBlock>
            <TextBlock Foreground="#FFBAC2DE" FontSize="11" Margin="0,3,0,0">
                <Run>GitHub:&#x2003;&#x2003;&#x2003;</Run><Hyperlink NavigateUri="https://github.com/landenlabs/win-widget-time.git"
                             RequestNavigate="Hyperlink_RequestNavigate"
                             Foreground="#FF89B4FA">https://github.com/landenlabs/win-widget-time.git</Hyperlink>
            </TextBlock>
            <TextBlock Margin="0,12,0,0" Foreground="#FF6C7086" FontSize="11">
                City lookup powered by OpenStreetMap Nominatim + GeoTimeZone.
            </TextBlock>
            <TextBlock Foreground="#FF6C7086" FontSize="11" Margin="0,3,0,0">
                Time zone data provided by TimeZoneConverter / IANA TZDB.
            </TextBlock>
        </StackPanel>

        <!-- Usage hints -->
        <StackPanel Grid.Row="5" Margin="0,16,0,0" VerticalAlignment="Top">
            <TextBlock Foreground="#FFA6ADC8" FontSize="11">
                <Run FontWeight="SemiBold" Foreground="#FF89B4FA">Hover</Run>
                <Run> the widget to reveal ⚙ and ? buttons.</Run>
            </TextBlock>
            <TextBlock Foreground="#FFA6ADC8" FontSize="11" Margin="0,3,0,0">
                <Run FontWeight="SemiBold" Foreground="#FF89B4FA">Drag</Run>
                <Run> the widget to reposition it on the desktop.</Run>
            </TextBlock>
            <TextBlock Foreground="#FFA6ADC8" FontSize="11" Margin="0,3,0,0">
                <Run FontWeight="SemiBold" Foreground="#FF89B4FA">Right-click</Run>
                <Run> for Settings, About, and Exit.</Run>
            </TextBlock>
        </StackPanel>

        <Button Grid.Row="6" Content="Close" Style="{StaticResource AccentButton}"
                HorizontalAlignment="Right" Click="Close_Click"/>
    </Grid>
</Window>
