<Window x:Class="WinWidgetTime.Windows.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Color"
        Width="320" Height="310"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E"
        Foreground="#FFCDD6F4"
        WindowStyle="SingleBorderWindow">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Choose a color" Foreground="#FFA6ADC8"
                   FontSize="12" Margin="0,0,0,10"/>

        <!-- Swatch grid -->
        <UniformGrid x:Name="SwatchGrid" Grid.Row="1" Rows="6" Columns="6"
                     Margin="0,0,0,12"/>

        <!-- Hex input row -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="44"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Hex:" Foreground="#FFA6ADC8"
                       VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox  Grid.Column="1" x:Name="HexBox"
                      Style="{StaticResource DarkTextBox}"
                      Text="#FFFFFF" MaxLength="9"
                      TextChanged="HexBox_TextChanged"/>
            <Border Grid.Column="3" x:Name="PreviewSwatch"
                    CornerRadius="4" Height="30" Width="44"
                    Background="White"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Style="{StaticResource SubtleButton}"
                    Margin="0,0,8,0" Click="Cancel_Click"/>
            <Button Content="OK"     Style="{StaticResource AccentButton}"
                    Click="OK_Click"/>
        </StackPanel>
    </Grid>
</Window>
